{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/handoff-receipt.schema.json",
  "title": "ChatGPT Implementation Handoff Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "status",
    "executor_profile",
    "branch",
    "base_sha",
    "commit_sha",
    "changed_files",
    "test_results",
    "verification_status",
    "blockers"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "status": {"enum": ["completed", "blocked"]},
    "executor_profile": {
      "enum": ["local_full", "github_connector"]
    },
    "branch": {"type": "string", "minLength": 1},
    "base_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "commit_sha": {
      "anyOf": [
        {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
        {"type": "null"}
      ]
    },
    "changed_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "test_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "status"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "status": {"enum": ["passed", "failed", "timed_out", "not_run"]},
          "exit_code": {"type": ["integer", "null"]},
          "output_tail": {"type": "string"}
        }
      }
    },
    "verification_status": {
      "enum": [
        "implementer_verified",
        "pending_codex_verification",
        "blocked"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "completed"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "commit_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
          "changed_files": {"minItems": 1},
          "blockers": {"maxItems": 0},
          "verification_status": {
            "enum": ["implementer_verified", "pending_codex_verification"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "commit_sha": {"type": "null"},
          "blockers": {"minItems": 1},
          "verification_status": {"const": "blocked"}
        }
      }
    }
  ]
}
