{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/collaboration.schema.json",
  "title": "ChatGPT-Codex Collaboration Contracts",
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "taskId": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "acceptanceCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "expected"],
      "properties": {
        "command": {"type": "string", "minLength": 1},
        "expected": {"type": "string", "minLength": 1},
        "timeout_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "taskContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "task_id", "objective", "repository", "branch", "authoritative_spec", "allowed_paths", "forbidden", "acceptance", "required_handoff", "mode_constraint"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "task_id": {"$ref": "#/$defs/taskId"},
        "objective": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "branch": {"type": "string", "minLength": 1},
        "base_sha": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]},
        "authoritative_spec": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["path", "reference"],
            "properties": {"path": {"type": "string", "minLength": 1}, "reference": {"type": "string", "minLength": 1}}
          }
        },
        "allowed_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "forbidden": {"type": "array", "items": {"type": "string"}},
        "acceptance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/acceptanceCommand"}},
        "required_handoff": {"type": "array", "minItems": 1, "items": {"enum": ["commit_sha", "changed_files", "test_results", "blockers"]}},
        "mode_constraint": {"const": "chat"},
        "push_partial_progress": {"const": false}
      }
    },
    "repairContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "task_id", "attempt", "observed_failure", "spec_requirement", "expected_behavior", "allowed_paths", "forbidden", "acceptance", "branch", "mode_constraint"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "task_id": {"$ref": "#/$defs/taskId"},
        "attempt": {"type": "integer", "minimum": 1},
        "observed_failure": {"type": "string", "minLength": 1},
        "spec_requirement": {"type": "string", "minLength": 1},
        "expected_behavior": {"type": "string", "minLength": 1},
        "allowed_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "forbidden": {"type": "array", "items": {"type": "string"}},
        "acceptance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/acceptanceCommand"}},
        "branch": {"type": "string", "minLength": 1},
        "base_sha": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]},
        "mode_constraint": {"const": "chat"}
      }
    },
    "transportEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "event_id", "task_id", "event_type", "source", "timestamp", "payload"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "event_id": {"type": "string", "minLength": 1},
        "task_id": {"$ref": "#/$defs/taskId"},
        "event_type": {"enum": ["task_dispatched", "generation_observed", "conversation_completed", "conversation_failed", "mode_drifted", "handoff_candidate", "handoff_missing", "transport_unreachable", "observation_lease_expired"]},
        "source": {"enum": ["codex", "chatgpt-ui", "github", "watcher", "user"]},
        "timestamp": {"type": "string", "format": "date-time"},
        "payload": {"type": "object"}
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "task_id", "branch", "base_sha", "commit_sha", "changed_files", "test_results", "blockers"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "task_id": {"$ref": "#/$defs/taskId"},
        "branch": {"type": "string", "minLength": 1},
        "base_sha": {"$ref": "#/$defs/sha"},
        "commit_sha": {"$ref": "#/$defs/sha"},
        "changed_files": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "test_results": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["command", "exit_code", "status"],
            "properties": {
              "command": {"type": "string"}, "exit_code": {"type": "integer"},
              "status": {"enum": ["passed", "failed", "timed_out", "not_run"]},
              "duration_seconds": {"type": "number", "minimum": 0}, "output_tail": {"type": "string"}
            }
          }
        },
        "blockers": {"type": "array", "items": {"type": "string"}}
      }
    },
    "acceptanceResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "task_id", "commit_sha", "status", "checks", "spec_summary", "changed_scope_valid"],
      "properties": {
        "schema_version": {"const": "1.0"}, "task_id": {"$ref": "#/$defs/taskId"},
        "commit_sha": {"$ref": "#/$defs/sha"}, "status": {"enum": ["accepted", "rejected", "blocked"]},
        "checks": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false, "required": ["name", "status"],
            "properties": {"name": {"type": "string", "minLength": 1}, "status": {"enum": ["passed", "failed", "blocked", "not_applicable"]}, "evidence": {"type": "string"}}
          }
        },
        "spec_summary": {"type": "string"}, "changed_scope_valid": {"type": "boolean"}, "repair_required": {"type": "boolean"}
      }
    },
    "taskState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "task_id", "state", "attempt", "repository", "conversation_url", "branch", "base_sha", "dispatch_id", "repair_count", "history", "updated_at"],
      "properties": {
        "schema_version": {"const": "1.0"}, "task_id": {"$ref": "#/$defs/taskId"},
        "state": {"enum": ["DISCOVERING", "READY", "DISPATCHING", "IMPLEMENTING", "WAITING_HANDOFF", "HANDOFF_CANDIDATE", "VERIFYING", "REPAIR_REQUIRED", "WAITING_REPAIR", "BLOCKED_SPEC", "BLOCKED_CAPABILITY", "BLOCKED_DEPENDENCY", "BLOCKED_TRANSPORT", "BLOCKED_OBSERVATION", "BLOCKED_USER", "ACCEPTED", "FAILED", "CANCELLED"]},
        "attempt": {"type": "integer", "minimum": 1}, "repository": {"type": "string", "minLength": 1},
        "conversation_url": {"type": "string", "minLength": 1}, "branch": {"type": "string", "minLength": 1},
        "base_sha": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]},
        "candidate_sha": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]},
        "accepted_sha": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]},
        "dispatch_id": {"type": "string", "minLength": 1}, "message_fingerprint": {"type": ["string", "null"]},
        "dispatched_at": {"type": ["string", "null"], "format": "date-time"},
        "observation": {
          "type": "object", "additionalProperties": false,
          "properties": {"lease_seconds": {"type": "integer", "minimum": 1}, "poll_seconds": {"type": "integer", "minimum": 1}, "dispatch_epoch": {"type": ["integer", "null"], "minimum": 0}, "absolute_deadline_epoch": {"type": ["integer", "null"], "minimum": 0}, "last_observed_state": {"type": ["string", "null"]}}
        },
        "repair_count": {"type": "integer", "minimum": 0}, "last_error": {"type": ["string", "null"]},
        "history": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false, "required": ["from", "to", "event", "timestamp"],
            "properties": {"from": {"type": ["string", "null"]}, "to": {"type": "string"}, "event": {"type": "string"}, "timestamp": {"type": "string", "format": "date-time"}}
          }
        },
        "updated_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
